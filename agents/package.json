{
  "name": "@faktura/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Faktura autonomous agent service: AI underwriter, collector, x402 risk oracle",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "e2e": "tsx src/e2e.ts",
    "mcp": "tsx src/mcp.ts",
    "x402-demo": "tsx src/x402-client.ts",
    "facilitator": "tsx scripts/mock-facilitator.ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "casper-js-sdk": "^2.15.6",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}