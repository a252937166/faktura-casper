# ---- Casper network ----
CASPER_NODE_ADDRESS=https://node.testnet.casper.network
CASPER_CHAIN_NAME=casper-test
CASPER_EVENTS_URL=https://node.testnet.casper.network/events

# ---- Deployed FakturaHub contract ("hash-...") ----
FAKTURA_CONTRACT=

# ---- Persona keys (Ed25519 PEM, casper-client keygen) ----
AGENT_KEY_PATH=keys/agent/secret_key.pem
INVESTOR_KEY_PATH=keys/investor/secret_key.pem
DEBTOR_KEY_PATH=keys/debtor/secret_key.pem

# ---- LLM underwriter ----
# auto = ANTHROPIC_API_KEY -> claude CLI -> deterministic mock
LLM_PROVIDER=auto
LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Collector ----
COLLECTOR_INTERVAL_MS=30000
# short grace so defaults are demonstrable live:
FAKTURA_GRACE_MS=90000

# ---- x402 oracle ----
X402_PRICE_MOTES=2500000000
