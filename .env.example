# ---- Casper network ----
CASPER_NODE_ADDRESS=https://node.testnet.casper.network
CASPER_CHAIN_NAME=casper-test
CASPER_EVENTS_URL=https://node.testnet.casper.network/events

# ---- Deployed FakturaHub contract ("hash-...") ----
FAKTURA_CONTRACT=

# ---- Persona keys (Ed25519 PEM — `make keys` generates all five) ----
AGENT_KEY_PATH=keys/agent/secret_key.pem
COLLECTOR_KEY_PATH=keys/collector/secret_key.pem
SUPPLIER_KEY_PATH=keys/supplier/secret_key.pem
INVESTOR_KEY_PATH=keys/investor/secret_key.pem
DEBTOR_KEY_PATH=keys/debtor/secret_key.pem

# ---- LLM underwriter ----
# auto = first available: OpenAI-compatible key -> Anthropic key -> local CLI -> deterministic mock
LLM_PROVIDER=auto
# DEEPSEEK_API_KEY=sk-...          (OpenAI-compatible)
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Collector ----
COLLECTOR_INTERVAL_MS=30000
# short grace so defaults are demonstrable live:
FAKTURA_GRACE_MS=90000

# ---- x402 oracle ----
X402_PRICE_MOTES=2500000000
# native-demo (default, self-contained) | official-facilitator (see docs/x402.md)
X402_MODE=native-demo
# X402_FACILITATOR_URL=

# ---- Hosted showcase (public demo without keys/gas) ----
# FAKTURA_SHOWCASE=1
# FAKTURA_SEED=agents/data/seed.json
